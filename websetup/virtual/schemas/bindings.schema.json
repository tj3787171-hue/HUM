{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/websetup/virtual/bindings.schema.json",
  "title": "SDV to virtual bindings",
  "type": "object",
  "required": ["version", "bindings"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string"
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "sdv", "virtual"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "sdv": {
            "type": "object"
          },
          "virtual": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
