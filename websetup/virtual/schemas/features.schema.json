{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/websetup/virtual/features.schema.json",
  "title": "Virtual phase feature flags",
  "type": "object",
  "required": ["phase", "version", "features"],
  "properties": {
    "phase": { "const": "virtual" },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "features": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["enabled"],
        "properties": {
          "enabled": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
