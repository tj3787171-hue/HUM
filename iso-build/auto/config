#!/usr/bin/env bash
set -euo pipefail

# Allow mirror overrides without editing this file.
DEBIAN_MIRROR="${HUM_DEBIAN_MIRROR:-http://deb.debian.org/debian/}"
DEBIAN_SECURITY_MIRROR="${HUM_DEBIAN_SECURITY_MIRROR:-http://security.debian.org/debian-security/}"

# "noauto" prevents recursive execution of auto/config.
lb config noauto \
  --mode debian \
  --distribution bookworm \
  --mirror-bootstrap "$DEBIAN_MIRROR" \
  --mirror-chroot "$DEBIAN_MIRROR" \
  --mirror-chroot-security "$DEBIAN_SECURITY_MIRROR" \
  --mirror-binary "$DEBIAN_MIRROR" \
  --mirror-binary-security "$DEBIAN_SECURITY_MIRROR" \
  --archive-areas "main contrib non-free non-free-firmware" \
  --binary-images iso-hybrid \
  --debian-installer none \
  --bootappend-live "boot=live components quiet splash" \
  "$@"
