#
# Copy this file to `.devcontainer/dev.env` and keep real values private.
# The `.devcontainer/dev.env` file is gitignored.
#

# Human-readable owner marker for runtime metadata.
HUM_OWNER_TAG=local-user

# Keep virtual desktop and browser debug listeners local by default.
HUM_VDESK_BIND=127.0.0.1
HUM_VDESK_PORT=6080
HUM_VNC_PORT=5901
HUM_CHROME_REMOTE_DEBUG_ADDR=127.0.0.1
HUM_CHROME_REMOTE_DEBUG_PORT=9222

# Optional proxy import from host/Penguin terminal.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal
ALL_PROXY=
